{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${mod_version}",
  "name": "${mod_name}",
  "description": "${mod_description}",
  "license": "${mod_license}",
  "icon": "icon.png",
  "authors": [
    "Magistu"
  ],
  "contributors": [
    "StaxiHD",
    "Mino",
    "Lexiolty",
    "Jackiecrazy",
    "CrazyBarkley",
    "Ryuje",
    "Witchkings",
    "Cole3050",
    "taizazanek",
    "thyreo"
  ],
  "contact": {
    "homepage": "${mod_page_url}",
    "issues": "${mod_issues_url}",
    "sources": "${mod_git_url}",
    "discord": "${mod_discord_url}"
  },
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.magistuarmory.fabric.EpicKnightsFabric"
    ],
    "client": [
      "com.magistuarmory.fabric.EpicKnightsFabricClient"
    ],
    "modmenu": [
      "com.magistuarmory.fabric.config.ModMenuFabric"
    ]
  },
  "depends": {
    "fabric": "*",
    "fabricloader": ">=${min_fabric_loader_version}",
    "minecraft": ">=${minecraft_min_version} <${minecraft_max_version}",
    "architectury": ">=${architectury_api_version}",
    "magistuarmory": ">=${epic_knights_version}",
    "cloth-config2": ">=${cloth_config_version}"
  },
  "custom": {
    "modmenu": {
      "links": {
        "modmenu.discord": "${mod_discord_url}"
      }
    }
  }
}